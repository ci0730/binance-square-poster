{
  "name": "binance-square-poster",
  "version": "1.0.6",
  "description": "Multi-account desktop tool for publishing and AI-assisted writing on Binance Square",
  "author": "Binance Square Poster",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node server.js",
    "desktop": "node scripts/run-desktop.cjs .",
    "desktop:bat": "scripts\\start-desktop.bat",
    "test": "node --test",
    "build:win": "node scripts/build-win.cjs",
    "release:win": "node scripts/build-win.cjs",
    "install:browser": "playwright install chromium"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "playwright": "^1.61.1",
    "socks": "^2.8.9"
  },
  "devDependencies": {
    "electron": "33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.binance-square.poster",
    "productName": "币安广场批量发帖",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "lib/**/*",
      "public/**/*",
      "server.js",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "package.json",
      "server.js",
      "lib/**",
      "public/**",
      "node_modules/electron-updater/**",
      "node_modules/playwright/**",
      "node_modules/playwright-core/**",
      "node_modules/socks/**"
    ],
    "extraResources": [
      {
        "from": "build/ms-playwright",
        "to": "ms-playwright",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraFiles": [
      {
        "from": "build/data-readme.txt",
        "to": "data/说明.txt"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "币安广场批量发帖",
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052",
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ci0730",
        "repo": "binance-square-poster",
        "releaseType": "release"
      }
    ],
    "releaseInfo": {
      "releaseNotes": "这款工具专为币安广场创作者设计，支持批量发帖、多账号管理，以及 AI 辅助写帖。\n\n我们重点打磨了四件事：\n\n**稳定可靠**\n对网络、代理相关逻辑做了排查与加固，减少异常中断和难懂的报错。\n\n**网络更省心**\n连接不稳时，软件会自动重试、自动处理，尽量不让你反复看到「网络错误」，把精力放在内容上。\n\n**界面更好用**\n布局按日常发帖流程优化，操作更顺、阅读更舒服，常用功能一眼能找到。\n\n**AI 写帖更完整**\nAI 生成内容更贴近广场风格：结构更清晰、信息更完整，减少半成品文案，改一改就能发。\n\n适合：要批量运营、多账号托管、又想少踩网络坑、少自己憋文案的创作者。"
    }
  }
}
