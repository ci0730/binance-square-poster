{
  "name": "binance-square-poster",
  "version": "1.0.13",
  "description": "Multi-account desktop tool for publishing and AI-assisted writing on Binance Square",
  "author": "Binance Square Poster",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node server.js",
    "desktop": "node scripts/run-desktop.cjs .",
    "desktop:bat": "scripts\\start-desktop.bat",
    "test": "node --test",
    "build:win": "node scripts/build-win.cjs",
    "release:win": "node scripts/build-win.cjs",
    "install:browser": "playwright install chromium"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "playwright": "^1.61.1",
    "socks": "^2.8.9"
  },
  "devDependencies": {
    "electron": "33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.binance-square.poster",
    "productName": "币安广场批量发帖",
    "beforePack": "./scripts/nsis-show-details.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "lib/**/*",
      "public/**/*",
      "server.js",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "package.json",
      "server.js",
      "lib/**",
      "public/**",
      "node_modules/electron-updater/**",
      "node_modules/playwright/**",
      "node_modules/playwright-core/**",
      "node_modules/socks/**",
      "node_modules/smart-buffer/**",
      "node_modules/ip-address/**"
    ],
    "extraResources": [
      {
        "from": "build/ms-playwright",
        "to": "ms-playwright",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraFiles": [
      {
        "from": "build/data-readme.txt",
        "to": "data/说明.txt"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "币安广场批量发帖",
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052",
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ci0730",
        "repo": "binance-square-poster",
        "releaseType": "release"
      }
    ],
    "releaseInfo": {
      "releaseNotes": "v1.0.13\n\n- 修复代理拉取互动失败（HTTPS 隧道 TLS）\n- 取消托管可立刻打断 AI 请求\n- 空轮次不再误报最近错误\n- 互动失败详情写入系统日志并可完整显示"
    }
  }
}
